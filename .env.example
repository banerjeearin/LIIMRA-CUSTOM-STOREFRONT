# Shopify Configuration
# Get these from: Shopify Admin → Settings → Apps and sales channels → Develop apps
VITE_SHOPIFY_STORE_DOMAIN=your-store-name.myshopify.com
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token_here

# Contact Information
VITE_WHATSAPP_NUMBER=919321731372
VITE_CONTACT_EMAIL=hello@liimra.com
VITE_SUPPORT_PHONE=+91-9321731372

# Feature Flags
VITE_ENABLE_COD=true
VITE_ENABLE_REVIEWS=true
VITE_FREE_SHIPPING_THRESHOLD=299
VITE_STANDARD_SHIPPING_COST=50

# Analytics (Optional)
# Get from: Google Analytics → Admin → Data Streams
VITE_GA_TRACKING_ID=
# Get from: Facebook Events Manager
VITE_FACEBOOK_PIXEL_ID=

# Error Tracking (Optional)
# Get from: sentry.io
VITE_SENTRY_DSN=

# Debug Mode (Development only)
VITE_DEBUG_MODE=false
